@page
@using ColorGoGo.Models
@model CIDM3312_Final.Pages.Orders.EditModel

@{
    ViewData["Title"] = "Edit Order";
}

<h1>Edit Order</h1>

<form method="post">
    <input type="hidden" asp-for="Order.OrderID" />

    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="form-group mb-3">
        <label asp-for="Order.OrderDate"></label>
        <input asp-for="Order.OrderDate" class="form-control" type="date" />
        <span asp-validation-for="Order.OrderDate" class="text-danger"></span>
    </div>

    <div class="form-group mb-3">
        <label asp-for="Order.Quantity"></label>
        <input asp-for="Order.Quantity" class="form-control" />
        <span asp-validation-for="Order.Quantity" class="text-danger"></span>
    </div>

    <div class="form-group mb-3">
        <label asp-for="Order.Status"></label>
        <select asp-for="Order.Status" class="form-control" asp-items="Html.GetEnumSelectList<OrderStatus>()"></select>
        <span asp-validation-for="Order.Status" class="text-danger"></span>
    </div>

    <div class="form-group mb-3">
        <label asp-for="Order.CustomerID">Customer</label>
        <select asp-for="Order.CustomerID" class="form-control" asp-items="ViewBag.CustomerID"></select>
    </div>

    <div class="form-group mb-3">
        <label asp-for="Order.ColoringBookID">Coloring Book</label>
        <select asp-for="Order.ColoringBookID" class="form-control" asp-items="ViewBag.ColoringBookID"></select>
    </div>

    <button type="submit" class="btn btn-primary">Save</button>
    <a asp-page="Index" class="btn btn-secondary">Back</a>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}