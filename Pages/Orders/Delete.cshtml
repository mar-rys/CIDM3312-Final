@page "{id:int}"
@model CIDM3312_Final.Pages.Orders.DeleteModel

<h1>Delete Order</h1>

<div class="alert alert-danger">
    Are you sure you want to delete this order?
</div>

<div class="card">
    <div class="card-body">
        <p><strong>Order Date:</strong> @Model.Order.OrderDate.ToShortDateString()</p>
        <p><strong>Status:</strong> @Model.Order.Status</p>
        <p><strong>Quantity:</strong> @Model.Order.Quantity</p>
        <p><strong>Customer:</strong> @(Model.Order.Customer?.CustomerName ?? "N/A")</p>
        <p><strong>Coloring Book:</strong> @(Model.Order.ColoringBook?.BookTitle ?? "N/A")</p>
    </div>
</div>

<form method="post" class="mt-3">
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-page="Index" class="btn btn-secondary">Cancel</a>
</form>