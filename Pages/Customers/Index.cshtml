@page
@model CIDM3312_Final.Pages.Customers.IndexModel

@{
    ViewData["Title"] = "Customers";
}

<h1>Customers</h1>

<p>
    <a asp-page="Create" class="btn btn-primary">Create New Customer</a>
</p>

<table class="table table-striped table-hover">
    <thead>
        <tr>
            <th>Customer Name</th>
            <th>Address</th>
            <th>Total Orders</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var customer in Model.Customers)
        {
            <tr>
                <td>@customer.CustomerName</td>
                <td>@customer.Address</td>
                <td>@customer.Orders.Count</td>
                <td>
                    <a asp-page="Details" asp-route-id="@customer.CustomerID">Details</a> |
                    <a asp-page="Edit" asp-route-id="@customer.CustomerID">Edit</a> |
                    <a asp-page="Delete" asp-route-id="@customer.CustomerID">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>